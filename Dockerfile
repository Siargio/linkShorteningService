# syntax=docker/dockerfile:1

# ============================================================
# ЭТАП 1. СБОРКА GO-ПРИЛОЖЕНИЯ
# ============================================================
#
# Используем полноценный официальный образ Go только во время сборки.
#
# В этом образе находятся:
#
#   - компилятор Go;
#   - стандартная библиотека;
#   - инструменты для загрузки модулей;
#   - необходимые системные компоненты.
#
# В финальный runtime-образ компилятор Go не попадёт.
FROM golang:1.26.5-bookworm AS builder

# Устанавливаем рабочую директорию внутри build-контейнера.
#
# Все последующие COPY и RUN будут выполняться относительно /src.
WORKDIR /src

# Сначала копируем только файлы модулей.
#
# Это сделано отдельно от копирования исходного кода,
# чтобы Docker мог кешировать слой с зависимостями.
#
# Если исходный код изменился, но go.mod и go.sum не менялись,
# Docker не будет заново скачивать все зависимости.
COPY go.mod go.sum ./

# Загружаем Go-зависимости:
#
#   - pgx;
#   - go-redis;
#   - godotenv;
#   - их транзитивные зависимости.
RUN go mod download

# Теперь копируем весь исходный код проекта.
#
# Файлы, указанные в .dockerignore, в образ не попадут.
COPY . .

# Собираем исполняемый Linux-файл.
#
# CGO_ENABLED=0:
#   отключает зависимость от системной C-библиотеки;
#   бинарный файл становится проще переносить между образами.
#
# GOOS=linux:
#   приложение внутри Docker запускается на Linux,
#   даже если сборка инициирована с macOS.
#
# -trimpath:
#   убирает локальные пути файловой системы из бинарника.
#
# -ldflags="-s -w":
#   убирает отладочную информацию и уменьшает размер файла.
#
# Результат будет записан в:
#
#   /out/shortener
RUN CGO_ENABLED=0 \
    GOOS=linux \
    go build \
    -trimpath \
    -ldflags="-s -w" \
    -o /out/shortener \
    ./cmd/shortener

# ============================================================
# ЭТАП 2. ФИНАЛЬНЫЙ RUNTIME-ОБРАЗ
# ============================================================
#
# В финальный образ не копируем:
#
#   - исходный код;
#   - компилятор Go;
#   - кеш модулей;
#   - тесты;
#   - инструменты разработки.
#
# Там будет только операционная система и бинарный файл приложения.
FROM debian:bookworm-slim AS runtime

# Устанавливаем:
#
# ca-certificates:
#   корневые сертификаты для безопасной работы с HTTPS/TLS.
#
# tzdata:
#   базу часовых поясов.
#
# После установки удаляем кеш apt,
# чтобы не увеличивать размер финального образа.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        tzdata \
    && rm -rf /var/lib/apt/lists/*

# Используем UTC внутри контейнера.
#
# Это помогает получать единообразное время
# независимо от часового пояса компьютера разработчика.
ENV TZ=UTC

# Рабочая директория runtime-контейнера.
WORKDIR /app

# Копируем только готовый бинарный файл
# из предыдущего этапа builder.
COPY --from=builder \
    --chown=65532:65532 \
    /out/shortener \
    /usr/local/bin/shortener

# Запускаем приложение не от root.
#
# UID/GID 65532 используется как непривилегированный пользователь.
# Приложению не нужны административные права.
USER 65532:65532

# Документируем порт, который слушает приложение.
#
# EXPOSE сам по себе не публикует порт на компьютере.
# Реальное сопоставление будет задано в docker-compose.yml.
EXPOSE 8080

# Команда, которая запускается при старте контейнера.
ENTRYPOINT ["/usr/local/bin/shortener"]